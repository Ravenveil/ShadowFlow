{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentGraph",
  "version": "0.1.0",
  "identifier": "com.agentgraph.app",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "../frontend",
    "beforeBuildCommand": "",
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "title": "AgentGraph",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
