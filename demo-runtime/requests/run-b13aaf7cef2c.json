            "topic": "product",
            "confidence": 7
          },
          "set_state": {
            "product_signal_ready": true
          }
        },
        "inputs": [],
        "outputs": [],
        "retry_policy": {},
        "metadata": {}
      },
      {
        "id": "research_b",
        "kind": "agent",
