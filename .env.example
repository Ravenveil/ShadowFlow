# ShadowFlow environment — copy to .env before `docker compose up`.
# NOTE (S1 red line): DO NOT commit real keys. Values MUST stay empty in this file.
# Per BYOK (bring-your-own-key) policy the primary API keys are stored in the
# browser's localStorage by the web UI. These server-side slots are optional
# and only used by backend-side features (offline bridge, CLI smoke, etc.).

# === LLM provider keys (optional on server; UI will prompt if absent) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# === 0G bridge endpoint (Storage / Compute) ===
# Leave empty to disable 0G integration. Example: http://localhost:3001
ZEROG_BRIDGE_URL=

# === 0G Compute provider (Story 5.4 — 第 5 provider) ===
# Required for 0G Compute inference. Private key MUST stay in .env, never hardcode.
ZEROG_RPC_URL=https://evmrpc-testnet.0g.ai
ZEROG_PRIVATE_KEY=
ZEROG_PROVIDER_ADDRESS=

# === 0G Chain contract (Story 15-2 RunRegistry) ===
# Deployed contract address on 0G Galileo testnet (chainId 16602).
# Run: npx hardhat run scripts/deploy_registry.js --network 0g-testnet
# Then paste the printed address here and in Vercel env vars.
VITE_RUN_REGISTRY_ADDRESS=

# === 0G Template Marketplace (Story 15-5 TemplateRegistry) ===
# Deployed contract address on 0G Galileo testnet (chainId 16602).
# Run: npx hardhat run scripts/deploy_template_registry.js --network 0g-testnet
# Then paste the printed address here. PRIVATE_KEY must be set (below) for deployment.
PRIVATE_KEY=                     # your 0G Galileo wallet private key (never commit!)
VITE_TEMPLATE_REGISTRY_ADDRESS=

# === CORS allow-list for the FastAPI server ===
# Comma-separated origins. For production set this to your Vercel URL.
# IMPORTANT: "*" is NOT valid here — Starlette raises RuntimeError with credentials.
# Local dev: http://localhost:5173,http://localhost:3000
# Production: https://shadowflow.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
